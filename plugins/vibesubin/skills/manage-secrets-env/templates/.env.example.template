# .env.example — starter template
#
# Drop this file at the repo root as `.env.example` and adapt the variables
# to your project. Then create a real `.env` next to it with the actual
# values. `.env` must be gitignored. `.env.example` is always committed.
#
# Every `__REPLACE_ME__` placeholder is a value the application must refuse
# to boot with. See `manage-secrets-env`'s "Startup validation" section.

# --- Required ---

# Primary database connection string.
# Fetch from your DB provider's dashboard (Supabase / Railway / RDS / etc.)
DATABASE_URL=__REPLACE_ME__

# Secret used to sign auth tokens and session cookies.
# Generate with:   openssl rand -hex 32
SESSION_SECRET=__REPLACE_ME__

# --- Optional (safe defaults) ---

# Logging noise level. One of: debug, info, warning, error
LOG_LEVEL=info

# Port the app binds to locally
PORT=8080

# --- Feature flags ---

# Enable experimental features. Set to 1 / true to enable.
FEATURE_EXPERIMENTAL=0

# --- External services (uncomment and fill as needed) ---

# Stripe live or test key for payments
# STRIPE_SECRET_KEY=__REPLACE_ME__

# SendGrid / Resend / Postmark API key for transactional email
# MAIL_API_KEY=__REPLACE_ME__

# Sentry DSN for error monitoring
# SENTRY_DSN=__REPLACE_ME__

# --- Never commit ---
# If you find yourself adding a value here that looks like a real secret,
# stop. Put the real value in `.env` (gitignored) and leave a
# `__REPLACE_ME__` placeholder here.
